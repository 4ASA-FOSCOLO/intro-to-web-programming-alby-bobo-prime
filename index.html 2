<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Indovina il Numero</title>

<style>
body{
    font-family: Arial;
    text-align:center;
    background:#111;
    color:white;
    margin-top:100px;
}

input{
    padding:10px;
    font-size:18px;
}

button{
    padding:10px 20px;
    font-size:18px;
    margin-left:10px;
    cursor:pointer;
}

#messaggio{
    margin-top:20px;
    font-size:22px;
}
</style>
</head>

<body>

<h1>🎮 Indovina il numero</h1>
<p>Ho scelto un numero da 1 a 100</p>

<input type="number" id="numero">
<button onclick="controlla()">Prova</button>

<div id="messaggio"></div>

<script>

let numeroSegreto = Math.floor(Math.random()*100)+1

function controlla(){

let tentativo = document.getElementById("numero").value
let messaggio = document.getElementById("messaggio")

if(tentativo == numeroSegreto){
messaggio.innerHTML = "🔥 Hai indovinato!"
}
else if(tentativo > numeroSegreto){
messaggio.innerHTML = "⬇️ Troppo alto"
}
else{
messaggio.innerHTML = "⬆️ Troppo basso"
}

}

</script>

</body>
</html>